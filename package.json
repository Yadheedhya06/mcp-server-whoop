{
  "name": "mcp-server-whoop",
  "version": "0.2.1",
  "mcpName": "io.github.Yadheedhya06/mcp-server-whoop",
  "description": "Local-first, read-only WHOOP MCP server with secure OAuth and AI-ready health signals",
  "type": "module",
  "bin": {
    "mcp-server-whoop": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./whoop": {
      "types": "./dist/whoop.d.ts",
      "import": "./dist/whoop.js"
    }
  },
  "files": [
    "dist",
    "scripts/security-audit.mjs",
    "README.md",
    "SECURITY.md",
    "SECURITY-EVIDENCE.md",
    "CHANGELOG.md",
    "LICENSE",
    "server.json"
  ],
  "scripts": {
    "build": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --test --import tsx test/*.test.ts",
    "security:audit": "node scripts/security-audit.mjs",
    "security:sbom": "npm sbom --sbom-format=cyclonedx > sbom.cdx.json",
    "check": "npm run build && npm test && npm run security:audit",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yadheedhya06/mcp-server-whoop.git"
  },
  "homepage": "https://github.com/Yadheedhya06/mcp-server-whoop#readme",
  "bugs": {
    "url": "https://github.com/Yadheedhya06/mcp-server-whoop/issues"
  },
  "author": "Yadheedhya06",
  "license": "MIT",
  "keywords": [
    "whoop",
    "mcp",
    "model-context-protocol",
    "health",
    "fitness",
    "recovery",
    "sleep",
    "hrv",
    "ai"
  ]
}
