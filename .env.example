# Create an app at https://developer.whoop.com/dashboard/
WHOOP_CLIENT_ID=your_client_id
WHOOP_CLIENT_SECRET=your_client_secret
WHOOP_REDIRECT_URI=http://127.0.0.1:8765/callback

# Optional overrides
# WHOOP_CREDENTIALS_FILE=/absolute/path/to/credentials.json
# WHOOP_ACCESS_TOKEN=short_lived_access_token
# WHOOP_REFRESH_TOKEN=rotating_refresh_token
# WHOOP_TOKEN_EXPIRES_AT=2026-01-01T00:00:00.000Z
